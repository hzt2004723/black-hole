<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>星际穿越: 卡冈图雅 (Gargantua)</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #000;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        #canvas-container {
            width: 100vw;
            height: 100vh;
            display: block;
        }
        #ui-layer {
            position: absolute;
            bottom: 20px;
            left: 20px;
            color: rgba(255, 255, 255, 0.85);
            pointer-events: none;
            z-index: 10;
        }
        h1 {
            margin: 0 0 5px 0;
            font-size: 28px;
            letter-spacing: 2px;
            text-shadow: 0 2px 10px rgba(0,0,0,1);
        }
        p {
            margin: 0;
            font-size: 14px;
            text-shadow: 0 1px 5px rgba(0,0,0,1);
            color: #aaa;
        }
        .highlight {
            color: #ff9900;
            font-weight: bold;
        }
        .loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-size: 20px;
            letter-spacing: 4px;
            transition: opacity 0.8s;
            z-index: 20;
        }
    </style>
    <!-- 引入 Three.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
</head>
<body>
    <div id="loading" class="loading">CALCULATING SPACETIME METRIC...</div>
    <div id="canvas-container"></div>
    <div id="ui-layer">
        <h1>GARGANTUA</h1>
        <p>真实物理模拟：<span class="highlight">引力透镜</span> 与 <span class="highlight">相对论多普勒效应</span></p>
        <p style="margin-top: 5px; font-size: 12px;">鼠标左键旋转视角 | 滚轮穿梭时空</p>
    </div>

    <script>
        window.onload = function() {
            setTimeout(() => {
                document.getElementById('loading').style.opacity = 0;
                setTimeout(() => document.getElementById('loading').style.display = 'none', 800);
            }, 500);
            init();
        };

        // 核心渲染变量
        let renderer, controls;
        let mainScene, mainCamera; // 渲染原始宇宙的场景
        let postScene, postCamera; // 用于引力透镜后处理的场景
        let renderTarget;          // 抓取原始场景的画布
        let postMaterial;          // 核心引力透镜着色器

        let accretionDisk;
        const clock = new THREE.Clock();
        
        // 物理常数设定
        const EVENT_HORIZON_RADIUS = 3.0; // 黑洞事件视界大小

        function init() {
            // ==========================================
            // 1. 初始化基础渲染器
            // ==========================================
            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // 限制像素比优化性能
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            // ==========================================
            // 2. 初始化主场景 (没有扭曲的原始宇宙)
            // ==========================================
            mainScene = new THREE.Scene();
            mainCamera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 1000);
            mainCamera.position.set(0, 8, 35);

            controls = new THREE.OrbitControls(mainCamera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.maxDistance = 150;
            controls.minDistance = 8;
            controls.enablePan = false; // 禁用平移，保持黑洞在宇宙中心

            createStarfield();
            createAccretionDisk(EVENT_HORIZON_RADIUS);

            // ==========================================
            // 3. 初始化后处理引力透镜 (The Magic)
            // ==========================================
            // 创建一个离屏渲染目标，保存没有扭曲的画面
            renderTarget = new THREE.WebGLRenderTarget(window.innerWidth, window.innerHeight, {
                minFilter: THREE.LinearFilter,
                magFilter: THREE.LinearFilter,
                format: THREE.RGBAFormat
            });

            postScene = new THREE.Scene();
            postCamera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
            
            // 核心：屏幕空间引力透镜着色器
            postMaterial = new THREE.ShaderMaterial({
                uniforms: {
                    tDiffuse: { value: renderTarget.texture }, // 原始画面
                    center: { value: new THREE.Vector2(0.5, 0.5) }, // 黑洞在屏幕上的位置
                    bhRadius: { value: 0.1 }, // 黑洞在屏幕上的视半径
                    aspectRatio: { value: window.innerWidth / window.innerHeight }
                },
                vertexShader: `
                    varying vec2 vUv;
                    void main() {
                        vUv = uv;
                        gl_Position = vec4(position, 1.0);
                    }
                `,
                fragmentShader: `
                    uniform sampler2D tDiffuse;
                    uniform vec2 center;
                    uniform float bhRadius;
                    uniform float aspectRatio;
                    varying vec2 vUv;

                    void main() {
                        vec2 uv = vUv;
                        vec2 delta = uv - center;
                        
                        // 修正屏幕宽高比，使得透镜是一个完美的圆
                        delta.x *= aspectRatio;
                        
                        float r = length(delta);

                        // 1. 事件视界内部：绝对的黑暗 (没有任何光能逃脱)
                        if (r < bhRadius) {
                            // 边缘添加一点极其微弱的光晕(光子圈残留)
                            float glow = smoothstep(bhRadius - 0.005, bhRadius, r) * 0.5;
                            gl_FragColor = vec4(glow, glow * 0.5, 0.0, 1.0);
                            return;
                        }

                        // 2. 引力透镜方程 (广义相对论弱场近似)
                        // r_source 是光线如果不被弯曲，它原本对应的径向距离
                        // 距离黑洞越近，光线弯曲得越厉害，r_source 被拉扯得越远
                        float r_source = r - (bhRadius * bhRadius) / r;
                        
                        vec2 dir = normalize(delta);

                        // 加入色散效应 (色差)：高能蓝光和低能红光在极端引力下的微小路径差异
                        // 这让吸积盘边缘产生电影级别的高级电影感色差
                        float r_source_r = r - (bhRadius * bhRadius * 0.98) / r;
                        float r_source_b = r - (bhRadius * bhRadius * 1.03) / r;

                        vec2 sourceUv_r = center + vec2(dir.x / aspectRatio, dir.y) * r_source_r;
                        vec2 sourceUv_g = center + vec2(dir.x / aspectRatio, dir.y) * r_source;
                        vec2 sourceUv_b = center + vec2(dir.x / aspectRatio, dir.y) * r_source_b;

                        // 分别采样RGB通道
                        float colR = texture2D(tDiffuse, sourceUv_r).r;
                        float colG = texture2D(tDiffuse, sourceUv_g).g;
                        float colB = texture2D(tDiffuse, sourceUv_b).b;

                        gl_FragColor = vec4(colR, colG, colB, 1.0);
                    }
                `
            });

            const postPlane = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), postMaterial);
            postScene.add(postPlane);

            window.addEventListener('resize', onWindowResize, false);
            animate();
        }

        function createStarfield() {
            const starGeometry = new THREE.BufferGeometry();
            const starCount = 5000;
            const starPositions = new Float32Array(starCount * 3);
            
            for(let i = 0; i < starCount; i++) {
                const r = 400 + Math.random() * 400;
                const theta = 2 * Math.PI * Math.random();
                const phi = Math.acos(2 * Math.random() - 1);
                starPositions[i*3] = r * Math.sin(phi) * Math.cos(theta);
                starPositions[i*3+1] = r * Math.sin(phi) * Math.sin(theta);
                starPositions[i*3+2] = r * Math.cos(phi);
            }

            starGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
            const starMaterial = new THREE.PointsMaterial({
                color: 0xffffff,
                size: 0.8,
                transparent: true,
                opacity: 0.6
            });
            mainScene.add(new THREE.Points(starGeometry, starMaterial));
        }

        // 创建高度还原的等离子体吸积盘
        function createAccretionDisk(bhRadius) {
            // 增加粒子数量以支持剧烈的空间拉伸
            const particleCount = 150000; 
            const geometry = new THREE.BufferGeometry();
            
            const positions = new Float32Array(particleCount * 3);
            const colors = new Float32Array(particleCount * 3);
            const randoms = new Float32Array(particleCount);

            // 盘的内外半径
            const innerRadius = bhRadius * 1.2; 
            const outerRadius = bhRadius * 8.0;

            const colorInner = new THREE.Color(0xffffff); // 极高温炽白
            const colorMiddle = new THREE.Color(0xffaa33); // 橙金
            const colorOuter = new THREE.Color(0x551100); // 暗红

            for(let i = 0; i < particleCount; i++) {
                // 非线性分布，让物质大量集中在黑洞附近
                const r = innerRadius + Math.pow(Math.random(), 2.0) * (outerRadius - innerRadius);
                const theta = Math.random() * Math.PI * 2;
                
                // 盘的厚度：外侧略厚，内侧极薄
                const thickness = (r - innerRadius) * 0.08;
                const y = (Math.random() - 0.5) * thickness;

                positions[i*3] = r * Math.cos(theta);
                positions[i*3+1] = y;
                positions[i*3+2] = r * Math.sin(theta);

                // 根据径向距离分配基础颜色
                const factor = (r - innerRadius) / (outerRadius - innerRadius);
                const pColor = new THREE.Color();
                if (factor < 0.2) pColor.lerpColors(colorInner, colorMiddle, factor / 0.2);
                else pColor.lerpColors(colorMiddle, colorOuter, (factor - 0.2) / 0.8);

                colors[i*3] = pColor.r;
                colors[i*3+1] = pColor.g;
                colors[i*3+2] = pColor.b;

                randoms[i] = Math.random();
            }

            geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
            geometry.setAttribute('customColor', new THREE.BufferAttribute(colors, 3));
            geometry.setAttribute('random', new THREE.BufferAttribute(randoms, 1));

            // 吸积盘着色器：处理多普勒束流和开普勒旋转
            const diskMaterial = new THREE.ShaderMaterial({
                uniforms: {
                    time: { value: 0.0 }
                },
                vertexShader: `
                    uniform float time;
                    attribute vec3 customColor;
                    attribute float random;
                    varying vec3 vColor;
                    
                    void main() {
                        float dist = length(position.xz);
                        
                        // 1. 开普勒旋转定律：越近转越快
                        float speed = 12.0 / sqrt(dist * dist * dist); 
                        float angle = speed * time * (0.8 + random * 0.4); 
                        
                        float s = sin(angle);
                        float c = cos(angle);
                        
                        vec3 newPos = vec3(
                            position.x * c - position.z * s,
                            position.y,
                            position.x * s + position.z * c
                        );
                        
                        // 2. 相对论多普勒效应 (Doppler Beaming)
                        // 计算粒子的切线运动方向
                        vec3 velocityDir = normalize(vec3(-newPos.z, 0.0, newPos.x));
                        // 计算从摄像机看向粒子的视线方向
                        vec3 viewDir = normalize(cameraPosition - newPos);
                        
                        // 点积判断朝向：正值表示迎面飞来，负值表示离我们而去
                        float doppler = dot(velocityDir, viewDir);
                        
                        // 迎面飞来的光被极端蓝移和增亮，远去的被红移和变暗
                        float brightness = 1.0 + doppler * 1.8; 
                        brightness = max(0.1, brightness); // 防止完全不可见
                        
                        // 应用颜色和亮度
                        vColor = customColor * brightness;
                        
                        // 添加一点微小的颜色偏移体现蓝移/红移
                        if (doppler > 0.0) vColor.b += doppler * 0.3; // 蓝移
                        if (doppler < 0.0) vColor.r -= doppler * 0.2; // 红移
                        
                        vec4 mvPosition = modelViewMatrix * vec4(newPos, 1.0);
                        gl_PointSize = (random * 2.0 + 1.0) * ( 80.0 / -mvPosition.z );
                        gl_Position = projectionMatrix * mvPosition;
                    }
                `,
                fragmentShader: `
                    varying vec3 vColor;
                    void main() {
                        // 绘制柔和的圆形发光粒子
                        vec2 pt = gl_PointCoord - vec2(0.5);
                        float r = length(pt);
                        if (r > 0.5) discard;
                        
                        float alpha = pow(1.0 - r * 2.0, 1.5);
                        gl_FragColor = vec4(vColor, alpha);
                    }
                `,
                blending: THREE.AdditiveBlending, // 加法混合，模拟光线叠加
                depthWrite: false,
                transparent: true
            });

            accretionDisk = new THREE.Points(geometry, diskMaterial);
            mainScene.add(accretionDisk);
        }

        function onWindowResize() {
            mainCamera.aspect = window.innerWidth / window.innerHeight;
            mainCamera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderTarget.setSize(window.innerWidth, window.innerHeight);
            postMaterial.uniforms.aspectRatio.value = window.innerWidth / window.innerHeight;
        }

        function animate() {
            requestAnimationFrame(animate);

            const elapsedTime = clock.getElapsedTime();

            if (accretionDisk) {
                accretionDisk.material.uniforms.time.value = elapsedTime;
            }

            controls.update();

            // ==========================================
            // 动态计算黑洞在屏幕上的物理大小和位置
            // 这是透镜随着镜头缩放保持正确的关键
            // ==========================================
            // 1. 计算黑洞中心在屏幕上的投影坐标 (NDC 坐标)
            const bhPosition = new THREE.Vector3(0, 0, 0);
            bhPosition.project(mainCamera);
            const screenX = (bhPosition.x + 1) / 2;
            const screenY = (bhPosition.y + 1) / 2;
            postMaterial.uniforms.center.value.set(screenX, screenY);

            // 2. 根据摄像机距离，计算黑洞的视半径
            const dist = mainCamera.position.distanceTo(new THREE.Vector3(0,0,0));
            const vFov = mainCamera.fov * Math.PI / 180;
            // 视野在黑洞所在平面的总高度
            const heightAtDist = 2.0 * Math.tan(vFov / 2.0) * dist;
            // 黑洞占屏幕高度的比例
            const sizeUv = EVENT_HORIZON_RADIUS / heightAtDist;
            postMaterial.uniforms.bhRadius.value = sizeUv;

            // ==========================================
            // 双通道渲染管线
            // ==========================================
            // 1. 先将原始宇宙(没有黑洞)渲染到隐藏的画布上
            renderer.setRenderTarget(renderTarget);
            renderer.clear();
            renderer.render(mainScene, mainCamera);

            // 2. 将隐藏画面交给引力透镜着色器，进行时空扭曲，输出到真实屏幕
            renderer.setRenderTarget(null);
            renderer.clear();
            renderer.render(postScene, postCamera);
        }
    </script>
</body>
</html>
